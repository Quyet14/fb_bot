# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://fb_bot_user:matkhau@localhost:5432/fb_bot_db
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=fb_bot_backend
USE_MONGODB=true

# ── API Keys ──────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Auth (JWT) ────────────────────────────────────────────────
# Tạo key ngẫu nhiên: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_random_secret_key_256bits
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
ALLOW_REGISTER=true

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Bot settings ──────────────────────────────────────────────
THU_MUC_ANH=C:/fb_images
GIOI_HAN_LIKE=5
GIOI_HAN_COMMENT=3
THOI_GIAN_CHO_GIUA_CAC_NHOM=150
HEADLESS_MODE=false
